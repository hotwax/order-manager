# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by accxui/.gitignore so it never enters version control.
#
# These credentials are used by:
#   - scripts/dev-login.mjs (headless API testing — prints a Bearer token)
#   - src/dev/autoLogin.ts  (skips the Login UI when running `pnpm dev` locally)
#
# Both paths are gated by Vite's DEV mode and are no-ops in production builds.

# --- App config (committed defaults live in .env.example; override here if needed) ---
VITE_I18N_LOCALE=en-US
VITE_I18N_FALLBACK_LOCALE=en-US
VITE_CACHE_MAX_AGE=3600
VITE_APP_PERMISSION_ID=ORDERMGR_VIEW
VITE_DEFAULT_LOG_LEVEL=error
VITE_OMS_TYPE=moqui
VITE_LAUNCHPAD_URL=http://launchpad.hotwax.io/login

# --- Dev-only auto-login (NEVER set these in a production .env) ---
# OMS instance hostname (the part before .hotwax.io) OR a full URL.
# Examples:
#   VITE_DEV_OMS=myinstance
#   VITE_DEV_OMS=https://my-custom-host.example.com
#   VITE_DEV_OMS=http://localhost:8080
VITE_DEV_OMS=http://localhost:8080

# Username and password the dev shim will submit on app boot.
VITE_DEV_USERNAME=hotwax.user
VITE_DEV_PASSWORD=

# Optional: set to "false" to disable auto-login even when the values above are set.
# Useful if you want to keep credentials in the file but exercise the Login UI manually.
VITE_DEV_AUTO_LOGIN=true
